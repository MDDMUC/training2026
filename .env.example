# Copy to .env.local and fill in. .env.local is gitignored.

# Supabase — Project Settings → API
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=

# Server-only
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=

# Anthropic — for natural-language → calorie/macro parsing on the Today page.
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
